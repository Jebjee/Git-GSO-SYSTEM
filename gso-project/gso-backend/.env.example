# ─────────────────────────────────────────
# GSO SYSTEM - ENVIRONMENT CONFIGURATION
# ─────────────────────────────────────────
# Copy this file and rename it to: .env
# Then fill in your actual values below

# Server Port
PORT=5000

# JWT Secret - change this to any random string
JWT_SECRET=gso_super_secret_key_change_this_2024

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Use "mysql" (recommended) or "sqlite" (local dev only)
DB_CLIENT=mysql

# MySQL connection settings
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=gso_system

# Security verification (for username/password change)
SECURITY_CODE_TTL_MINUTES=10
SECURITY_CODE_MIN_RETRY_SECONDS=60
SECURITY_CODE_MAX_ATTEMPTS=5

# ─────────────────────────────────────────
# ADMIN CREDENTIALS
# ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─────────────────────────────────────────
# EMAIL SETUP (Gmail)
# ─────────────────────────────────────────
# Step 1: Use your Gmail address below
# Step 2: Get App Password from Gmail:
#   → Go to myaccount.google.com
#   → Security → 2-Step Verification (enable it)
#   → Search "App Passwords"
#   → Select app: Mail → Generate
#   → Copy the 16-character password
# Step 3: Paste it in SMTP_PASS below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Email where admin receives notifications
ADMIN_EMAIL=your_gmail@gmail.com

# ─────────────────────────────────────────
# NOTE: If email is not configured,
# emails will just be printed in the
# terminal (simulation mode)
# ─────────────────────────────────────────
